# App 2 — Tender Document Risk Analyzer
# contract-analysis/.gitignore

# ─────────────────────────────────────────
# Research/dev artifacts — not for version control
# ─────────────────────────────────────────

# Block 4 research scripts (not production code)
test.py
test_*.py
*_test.py
regex_exercises.py

# Local exercise files / scratch
scratch/
sandbox/
exercises/

# ─────────────────────────────────────────
# PDF documents — too large, potentially confidential
# ─────────────────────────────────────────
*.pdf

# Exception: if you create a sample_contracts/ folder with anonymized
# test contracts, whitelist it explicitly:
# !sample_contracts/*.pdf

# ─────────────────────────────────────────
# Python
# ─────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so
.pytest_cache/
.mypy_cache/
htmlcov/
.coverage
dist/
build/
*.egg-info/

# Virtual environments
venv/
.venv/
env/
.env/

# ─────────────────────────────────────────
# Environment variables
# ─────────────────────────────────────────
.env
.env.local
.env.*.local
*.env

# ─────────────────────────────────────────
# Frontend build artifacts
# ─────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
frontend/build/

